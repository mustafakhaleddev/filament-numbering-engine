{
    "name": "wezlo/filament-numbering-engine",
    "description": "Configurable auto-numbering engine for Filament",
    "keywords": ["laravel", "filament", "numbering", "sequence", "auto-number"],
    "license": "MIT",
    "version": "1.0.0",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Wezlo\\FilamentNumberingEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wezlo\\FilamentNumberingEngine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wezlo\\FilamentNumberingEngine\\FilamentNumberingEngineServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
